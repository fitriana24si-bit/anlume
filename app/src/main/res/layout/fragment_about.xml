<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tentang Aplikasi"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:paddingBottom="16dp"/>

        <!-- CARD DESKRIPSI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplikasi Bina Desa"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#6C63FF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplikasi ini dirancang untuk membantu pengelolaan dan penyampaian informasi desa secara digital sehingga masyarakat dapat mengakses layanan dengan lebih mudah dan cepat."
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- CARD TUJUAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tujuan"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#6C63FF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Meningkatkan efisiensi pelayanan desa serta memberikan kemudahan akses informasi bagi masyarakat."
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD FITUR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fitur Utama"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#6C63FF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Informasi Desa\n• Layanan Masyarakat\n• Dashboard Interaktif\n• Akses Website Desa"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD INFO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:elevation="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Informasi"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#22C55E"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Versi 1.0\nDikembangkan oleh Mahasiswa Sistem Informasi"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:paddingTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>