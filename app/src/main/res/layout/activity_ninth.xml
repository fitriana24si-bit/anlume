<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".Home.pertemuan_9.NinthActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="@drawable/bg_header_dokumen"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dokumen Publik Desa"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Layanan digital informasi dan arsip desa"
                    android:textColor="#EDE9FE"
                    android:textSize="14sp"
                    android:paddingTop="6dp"/>
            </LinearLayout>

            <!-- DESKRIPSI -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Menu ini digunakan untuk melihat dokumen publik desa seperti laporan desa, regulasi, data penduduk dan arsip layanan masyarakat."
                android:textColor="#374151"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp"/>

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnMasukDokumen"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Masuk ke Dokumen Publik"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7C3AED"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>