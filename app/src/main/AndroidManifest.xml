        android:supportsRtl="true"
        android:theme="@style/Theme.Anaanlume"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".BaseActivity"
            android:exported="false" />
        <!-- WEBVIEW -->
        <activity
            android:name=".Home.pertemuan_6.WebViewActivity"
            android:exported="false" /> <!-- SPLASH (JADI HALAMAN PERTAMA) -->
