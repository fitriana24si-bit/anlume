            android:name=".Home.pertemuan_6.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- LAINNYA -->
        <activity
            android:name=".Home.pertemuan_4.DashboardActivity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_3.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_3.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_3.WelcomeActivity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_4.BangunRuangActivity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_4.Custom1Activity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_4.Custom2Activity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan_2.CalcuActivity"
            android:exported="false" />
        <activity
            android:name=".pertemuan_2.MainActivity"
            android:exported="false" />
    </application>

</manifest>