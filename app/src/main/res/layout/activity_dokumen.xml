<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".Home.dokumen.DokumenActivity">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/bg_header_dokumen"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dokumen Publik"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Layanan dokumen digital Bina Desa"
                    android:textSize="14sp"
                    android:textColor="#EDE9FE"
                    android:paddingTop="6dp"/>

            </LinearLayout>

            <!-- SEARCH -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cari dokumen..."
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CHIP GROUP -->
            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="16dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semua"
                    android:textColor="#FFFFFF"
                    android:checked="true"
                    app:chipBackgroundColor="#6C63FF"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPemerintah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pemerintah"
                    android:textColor="#6C63FF"
                    app:chipBackgroundColor="#EDE9FE"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLayanan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Layanan"
                    android:textColor="#6C63FF"
                    app:chipBackgroundColor="#EDE9FE"/>

            </com.google.android.material.chip.ChipGroup>

            <!-- GRID LAYOUT -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="18dp">

                <!-- CARD 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_menu_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- ICON ADMINISTRASI -->
                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@android:drawable/ic_menu_edit"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Administrasi"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:paddingTop="8dp"/>
                </LinearLayout>

                <!-- CARD 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_menu_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- ICON PELAYANAN -->
                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@android:drawable/ic_menu_send"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pelayanan"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:paddingTop="8dp"/>
                </LinearLayout>

            </GridLayout>

            <!-- TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Daftar Dokumen"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:paddingBottom="10dp"/>

            <!-- LISTVIEW -->
            <ListView
                android:id="@+id/listDokumen"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:divider="@android:color/transparent"
                android:dividerHeight="10dp"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>